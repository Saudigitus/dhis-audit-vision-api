# Database config
DB_NAME=dhis2_audit_vision
DB_USER=postgres
DB_PASSWORD=replace_with_a_secure_database_password
DB_HOST=127.0.0.1
DB_PORT=5433
ENVIRONMENT=development

# Server config
HOST=0.0.0.0
PORT=8000

SERVER_DHIS2_URL=https://example.org
SERVER_DHIS2_AUTH=replace_with_base64_credentials
# Optional path to a private CA certificate bundle. Standard public CAs need no override.
# DHIS2_CA_BUNDLE=/path/to/ca-bundle.pem
SQL_VIEW_ID=yzUJJJzDYkM
RETRIEVE_SQL_VIEW_ID=aloNfrH2RGq


CONTROL_FILE_PATH=./data/control_file.json
DATA_BASE_DIR=./data


SECRET_KEY=replace_with_a_random_secret_at_least_32_bytes
TOKEN_EXPIRE_MINUTES=60
# Optional static token for DHIS2 event hooks using auth.type=api-token.
# Generate a high-entropy value and configure the same value in DHIS2.
# WEBHOOK_API_TOKEN=replace_with_a_random_webhook_token_at_least_32_bytes

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.org
ADMIN_PASSWORD=replace_with_a_secure_password

OFFSET_HOURS=2

# Comma-separated browser origins. Leave empty when browser access is not required.
CORS_ALLOW_ORIGINS=http://localhost:3000
MAX_REQUEST_BODY_BYTES=1048576
LOG_MAX_BYTES=262144
LOG_ROTATION_MAX_BYTES=5242880
LOG_ROTATION_BACKUP_COUNT=5
DHIS2_OBJECT_FIELDS=id,name,displayName,code,created,lastUpdated
DHIS2_PROGRAM_DEPENDENCY_FIELDS=id,programStages[id,programStageDataElements[id,dataElement[id]],programStageSections[id]],programIndicators[id],programRules[id],programRuleVariables[id],trackedEntityType[id],categoryCombo[id],organisationUnits[id],attributeValues[attribute[id],value]
DHIS2_DATASET_DEPENDENCY_FIELDS=id,dataSetElements[id,dataElement[id]],sections[id,dataElements[id]],categoryCombo[id],organisationUnits[id],indicators[id],attributeValues[attribute[id],value]

# Email config

EMAIL_HOST=smtp.example.org
EMAIL_PORT=587
EMAIL_HOST_USER=replace_with_smtp_username
EMAIL_HOST_PASSWORD=replace_with_smtp_password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

# DHIS2 Configuration
DHIS2_IMAGE=dhis2/core:2.40.0.1
DHIS2_PORT=8080
DHIS2_DB_NAME=dhis
DHIS2_DB_USER=dhis
DHIS2_DB_PASSWORD=dhis
DHIS2_DB_EXPOSED_PORT=5434
DHIS2_DB_DUMP_URL=https://databases.dhis2.org/sierra-leone/2.40/dhis2-db-sierra-leone.sql.gz
